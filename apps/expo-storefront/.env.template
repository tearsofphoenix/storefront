# Medusa Store API 发布密钥，可在 Admin -> Settings -> Publishable API Keys 获取
EXPO_PUBLIC_MEDUSA_PUBLISHABLE_API_KEY=

# Medusa 后端地址。真机调试时请填写宿主机局域网 IP，例如 http://192.168.1.100:9000
EXPO_PUBLIC_MEDUSA_URL=

# Web storefront 地址，用于第三方登录等需要 HTTPS callback 的场景。
# 例如本地开发可填写 http://localhost:8000，线上请填写真实 storefront 域名。
EXPO_PUBLIC_STOREFRONT_URL=
